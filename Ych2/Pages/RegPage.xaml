<Page x:Class="Ych2.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ych2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1100" d:DesignWidth="800"
      Title="RegPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="РЕГИСТРАЦИЯ СОТРУДНИКА" Grid.Row="0" FontSize="28" FontFamily="Candara" 
                   HorizontalAlignment="Center" Margin="0,30,0,20" FontWeight="Bold"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="50,0,50,20" HorizontalAlignment="Center" Width="500">
                <Border BorderBrush="#355CBD" BorderThickness="1" CornerRadius="5" Margin="0,10">
                    <StackPanel Margin="15">
                        <TextBlock Text="ЛИЧНЫЕ ДАННЫЕ" FontWeight="Bold" FontSize="16" Foreground="#355CBD" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Имя:" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtName" Width="300" Height="30" Padding="5" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Фамилия:" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSurname" Width="300" Height="30" Padding="5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Отчество:" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPatronumic" Width="300" Height="30" Padding="5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Дата рождения:" Width="150" VerticalAlignment="Center" Margin="0 0 5 0"/>
                            <DatePicker x:Name="dpBirthday" Width="300" Height="40"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

 
                <Border BorderBrush="#355CBD" BorderThickness="1" CornerRadius="5" Margin="0,10">
                    <StackPanel Margin="15">
                        <TextBlock Text="ПАСПОРТНЫЕ ДАННЫЕ" FontWeight="Bold" FontSize="16" Foreground="#355CBD" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Серия паспорта:" Width="150" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <TextBox x:Name="txtPassportSeria" Width="300" Height="30" Padding="5" MaxLength="4"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Номер паспорта:"  Width="150" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <TextBox x:Name="txtPassportNumber" Width="300" Height="30" Padding="5" MaxLength="6"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Банковские реквизиты:"  Width="220" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <TextBox x:Name="txtBankDetails" Width="300" Height="30" Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#355CBD" BorderThickness="1" CornerRadius="5" Margin="0,10">
                    <StackPanel Margin="15">
                        <TextBlock Text="ДОПОЛНИТЕЛЬНАЯ ИНФОРМАЦИЯ" FontWeight="Bold" FontSize="16" Foreground="#355CBD" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Семейное положение:"  Width="220" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <ComboBox x:Name="cmbFamilyStatus" Width="300" Height="30" DisplayMemberPath="NmaeStatus"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Состояние здоровья:"  Width="210" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <ComboBox x:Name="cmbHealth" Width="300" Height="30" DisplayMemberPath="NameHealth"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Должность:"  Width="150" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <ComboBox x:Name="cmbRole" Width="300" Height="30" DisplayMemberPath="NameRole"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#355CBD" BorderThickness="1" CornerRadius="5" Margin="0,10">
                    <StackPanel Margin="15">
                        <TextBlock Text="ДАННЫЕ ДЛЯ ВХОДА" FontWeight="Bold" FontSize="16" Foreground="#355CBD" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Логин:" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtLogin" Width="300" Height="30" Padding="5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Пароль:" Width="120" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="pswPassword" Width="300" Height="30"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Подтверждение:"  Width="180" VerticalAlignment="Center " Margin="0,0,5,0"/>
                            <PasswordBox x:Name="pswConfirmPassword" Width="300" Height="30"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <Button Content="ЗАРЕГИСТРИРОВАТЬ" Name="btnRegister" Width="200" Height="40" 
                            Click="btnRegister_Click" Background="#355CBD" Foreground="White" 
                            Padding="5" Margin="0,0,10,0"/>
                    <Button Content="НАЗАД" Name="btnBack" Width="150" Height="40" 
                            Click="btnBack_Click" Background="White" Foreground="#355CBD" 
                            BorderBrush="#355CBD" Padding="5"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>