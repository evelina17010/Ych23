<Page x:Class="Ych2.Pages.PartnerHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ych2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
       Title="PartnerHistoryPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#355CBD" Padding="20">
            <StackPanel>
                <TextBlock x:Name="txtPartnerName" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtPartnerInfo" FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        <ListView x:Name="HistoryLv" Grid.Row="1" Margin="20">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Наименование продукции" Width="350" DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Количество" Width="150" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Дата продажи" Width="200" DisplayMemberBinding="{Binding SaleDate}"/>
                    <GridViewColumn Header="Сумма" Width="150" DisplayMemberBinding="{Binding Amount}"/>
                    <GridViewColumn Header="Точка продажи" Width="250" DisplayMemberBinding="{Binding SalePoint}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Общая сумма продаж:" FontSize="18" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtTotalAmount" FontSize="18" FontWeight="Bold" Foreground="#355CBD"/>
            </StackPanel>
        </Border>
        <Button Content="НАЗАД" Name="btnBack" Grid.Row="2" Width="150" Height="40" 
                Click="btnBack_Click" Background="#355CBD" Foreground="White" 
                HorizontalAlignment="Left" Margin="20,0,0,0" VerticalAlignment="Center"/>
    </Grid>
</Page>
