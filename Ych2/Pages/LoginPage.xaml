<Page x:Class="Ych2.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ych2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"  Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="ВХОД" Grid.Column="1" Grid.Row="0" FontSize="24" FontFamily="Candara" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,50,0,30"/>
        <StackPanel  Grid.Column="1" Grid.Row="1" Margin="0,0,0,20">
            <StackPanel   Orientation="Horizontal" Margin="10 50 0 0" HorizontalAlignment="Center">
                <TextBlock FontSize="18" Margin="10">Логин</TextBlock>
                <TextBox Name="txbLogin" Width="200" Height="50" Padding="5"/>
            </StackPanel>
            <StackPanel   Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                <TextBlock FontSize="18" Margin="10">Пароль</TextBlock>
                <PasswordBox Name="pswbPassword" Width="200" Height="50"/>
            </StackPanel >
            <Button Content="ВХОД" Name="btnVhod" Margin="10 40 10 10" Width="270" Height="50" Click="btnVhod_Click" Background="#355CBD" Foreground="White" Padding="5" HorizontalAlignment="Center"/>
            <Button Content="Регистрация" Name="btnReg" Margin="3" Width="270" Height="50" Click="btnReg_Click" Background="White"   Foreground="#355CBD" Padding="5" BorderBrush="#355CBD" HorizontalAlignment="Center"/>

        </StackPanel>
    </Grid>

</Page>
