<Page x:Class="Ych2.Pages.PartnerListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ych2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="PartnerListPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="ПОИСК:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" FontWeight="Bold"/>
            <TextBox x:Name="SearchTextBox" Width="250" Height="30" Margin="0,0,20,0" VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Text="СОРТИРОВКА:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" FontWeight="Bold"/>
            <ComboBox x:Name="SortComboBox" Width="180" Height="30" VerticalAlignment="Center" SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                <ComboBoxItem Content="По названию (A-Z)"/>
                <ComboBoxItem Content="По названию (Z-A)"/>
            </ComboBox>
        </StackPanel>

        <ListView x:Name="PartnersLv" Grid.Row="1" SelectionChanged="PartnersLv_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="10" Width="700" Height="170" HorizontalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <TextBlock Text="{Binding TypeOfBusiness.NameBusiness}" Margin="10 5 0 0" FontSize="24"/>
                                <TextBlock Text="|" Margin="0 5 0 0" FontSize="24"/>
                                <TextBlock Text="{Binding NamePartner}" FontSize="24" Margin="0 5 0 0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Grid.Row="1">
                                <TextBlock Text="{Binding SurnameDirector}" Margin="10 0 5 0"/>
                                <TextBlock Text="{Binding NameDirector}" Margin="5 0 5 0"/>
                                <TextBlock Text="{Binding PatronumicDirector}" Margin="5 0 5 0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{Binding Phone}" Margin="10 0 0 0"/>
                            <TextBlock Grid.Row="3" Text="{Binding Raiting}" Margin="10 0 0 0"/>
                            <TextBlock Grid.Column="1" Grid.Row="0" Grid.RowSpan="4" HorizontalAlignment="Center" Margin="10" FontSize="16" VerticalAlignment="Center" Text="{Binding SizeDiscount}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Orientation="Horizontal" Grid.Row="2">
            <Button Content="Добавить" Name="btnAdd" Margin="10 30 5 10" Width="150" Height="50" Click="btnAdd_Click" Background="#355CBD" Foreground="White" Padding="5" HorizontalAlignment="Center"/>
            <Button Content="Изменить" Name="btnEdit" Margin="10 30 5 10" Width="150" Height="50" Click="btnEdit_Click" Background="#355CBD" Foreground="White" Padding="5" HorizontalAlignment="Center"/>
            <Button Content="Удалить" Name="btnDelete" Margin="10 30 5 10" Width="150" Height="50" Click="btnDelete_Click" Background="#FF4444" Foreground="White" Padding="5"/>
            <Button Content="История продаж" Name="btnHistory" Margin="10 30 5 10" Width="170" Height="50" Click="btnHistory_Click" Background="#355CBD" Foreground="White" Padding="5"/>
        </StackPanel>
    </Grid>
</Page>